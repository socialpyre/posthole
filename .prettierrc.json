{
  "semi": true,
  "singleQuote": false,
  "trailingComma": "all",
  "tabWidth": 2,
  "printWidth": 100,
  "endOfLine": "lf",
  "proseWrap": "preserve",
  "plugins": ["prettier-plugin-jinja-template"],
  "overrides": [
    {
      "files": ["*.html.j2", "*.html.jinja", "*.jinja"],
      "options": { "parser": "jinja-template" }
    }
  ]
}
