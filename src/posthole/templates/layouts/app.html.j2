<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>{% block page_title %}posthole{% endblock %}</title>

    <script>
      (function () {
        var c = "light";
        try {
          c = localStorage.getItem("posthole:theme") || "light";
        } catch (e) {}
        var dark =
          c === "dark" ||
          (c === "system" && window.matchMedia("(prefers-color-scheme: dark)").matches);
        var h = document.documentElement;
        h.setAttribute("data-theme", dark ? "dark" : "light");
        h.setAttribute("data-theme-choice", c);
        try {
          if (localStorage.getItem("posthole:sidebar-collapsed") === "1") {
            h.setAttribute("data-sidebar-collapsed", "");
          }
        } catch (e) {}
        try {
          var p = localStorage.getItem("posthole:phone-preset");
          if (p) h.setAttribute("data-phone-preset", p);
        } catch (e) {}
      })();
    </script>

    <link rel="icon" type="image/svg+xml" href="{{ url_for('static', path='favicon.svg') }}" />
    <link rel="stylesheet" href="{{ url_for('static', path='app.css') }}" />
    <script type="module" src="{{ url_for('static', path='app.js') }}"></script>

    {% if DEV_RELOAD %}
      <script>
        const proto = location.protocol === "https:" ? "wss:" : "ws:";
        const ws = new WebSocket(`${proto}//${location.host}/hot-reload`);
        ws.onmessage = () => location.reload();
      </script>
    {% endif %}

    {% block head %}
    {% endblock %}
  </head>

  <body class="h-screen overflow-hidden bg-(--bg) text-(--fg)">
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:fixed focus:left-2 focus:top-2 focus:z-50
             focus:rounded focus:bg-(--accent) focus:px-3 focus:py-1.5
             focus:font-semibold focus:text-white focus:shadow"
      >Skip to main content</a
    >

    <button
      type="button"
      data-controller="sidebar"
      data-action="click->sidebar#close"
      aria-label="Close menu"
      data-drawer-overlay
      class="fixed inset-0 z-40 hidden bg-black/45 backdrop-blur-sm lg:hidden"
    ></button>

    <div class="flex h-full">
      {% include "partials/sidenav.html.j2" %}

      <div class="flex min-w-0 flex-1 flex-col">
        {% include "partials/topbar.html.j2" %}
        <main
          id="main-content"
          tabindex="-1"
          class="flex-1 min-w-0 min-h-0 overflow-hidden focus:outline-none"
        >
          {% block main %}{% endblock %}
        </main>
      </div>
    </div>

    {% block scripts %}{% endblock %}
  </body>
</html>
