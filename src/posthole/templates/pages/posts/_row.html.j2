{% from "macros/post_link.html.j2" import posts_link %}
{% from "macros/status_pill.html.j2" import status_pill %}
{% set username = usernames.get(p.account_id) %}
{% set caption = (p.caption or '')|replace('\n', ' ')|trim %}
{% set is_selected = selected and selected.id == p.id %}
{% set first_media = p.media[0] if p.media else none %}
{% set is_image = first_media and first_media.kind == "IMAGE" %}
{% set carousel_count = p.media|length if p.media|length > 1 else 0 %}

<li class="border-b border-dashed border-(--border) last:border-b-0">
  {# Selection styling comes from the global `[aria-current="page"]` CSS
     rule in styles.css — driven by `aria-current` only, not Tailwind
     classes. The Stimulus `list-selection` controller updates aria-current
     optimistically on click; if we also baked selection classes here, the
     Turbo Frame swap (which only replaces the detail pane) would leave
     the previous selection's classes behind and two rows would look
     selected at once. #}
  <a
    class="relative flex gap-3 border-l-2 border-transparent px-4 py-3 transition
           hover:bg-(--hover)"
    data-action="click->list-selection#select"
    data-list-selection-target="row"
    data-turbo-frame="post-detail"
    href="{{ posts_link(post_id=p.id, q=q, platform=platform, status=status) }}"
    {% if is_selected %}aria-current="page"{% endif %}
  >
    <div
      class="relative h-11 w-11 shrink-0 overflow-hidden rounded-md
             border border-(--border) bg-(--code)"
    >
      {% if is_image %}
        <img src="{{ first_media.url }}" alt="" class="h-full w-full object-cover" />
      {% else %}
        <div
          class="flex h-full w-full items-center justify-center
                 font-mono text-[10px] uppercase text-(--muted)"
        >
          {{ 'IG' if p.platform == 'instagram' else 'TT' }}
        </div>
      {% endif %}
      {% if carousel_count %}
        <span
          class="absolute right-1 top-1 flex h-3.5 min-w-3.5 items-center
                 justify-center rounded-[3px] bg-black/55 px-1 font-mono
                 text-[9px] font-bold text-white"
          >{{ carousel_count }}</span
        >
      {% endif %}
    </div>

    <div class="min-w-0 flex-1">
      <div class="flex items-center gap-2 text-[12px]">
        <span class="truncate font-semibold text-(--fg)">@{{ username or p.account_id }}</span>
        <span class="ml-auto font-mono text-[10px] text-(--muted)">
          {{ p.created_at.strftime('%H:%M:%S') }}
        </span>
      </div>

      <p class="mt-0.5 line-clamp-2 text-[12px] leading-snug text-(--sub)">
        {{ (caption | truncate(90, true, '…')) if caption else '(no caption)' }}
      </p>

      <div class="mt-1.5 flex items-center gap-2">
        {{ status_pill(p.status) }}
        <span class="font-mono text-[10px] text-(--muted)">{{ p.platform }}</span>
      </div>
    </div>
  </a>
</li>
