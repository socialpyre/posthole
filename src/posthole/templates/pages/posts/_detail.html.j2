{% from "macros/icon.html.j2" import icon %}
{% from "macros/post_link.html.j2" import posts_link %}
{% from "macros/status_pill.html.j2" import status_pill %}
{% from "macros/tabs.html.j2" import tabs, tablist, tabpanel %}

{% set username = usernames.get(selected.account_id) %}
{% set display_name = display_names.get(selected.account_id) %}
{% set thumb = selected.media[0] if selected.media else none %}
{% set thumb_is_image = thumb and thumb.kind == "IMAGE" %}

<div class="flex h-full min-h-0 flex-col bg-(--bg)">
  <header
    class="sticky top-0 z-10 flex items-center gap-3 border-b border-(--border)
           bg-(--panel) px-4 py-2.5"
  >
    <a
      href="{{ posts_link(q=q, platform=platform, status=status) }}"
      data-turbo-frame="_top"
      aria-label="Back to inbox"
      class="flex h-8 w-8 shrink-0 items-center justify-center rounded text-(--sub)
             hover:bg-(--hover) lg:hidden"
      >{{ icon("chev-left", 16) }}</a
    >

    <div
      class="relative h-8 w-8 shrink-0 overflow-hidden rounded-md border border-(--border)
             bg-(--code)"
      aria-hidden="true"
    >
      {% if thumb_is_image %}
        <img src="{{ thumb.url }}" alt="" class="h-full w-full object-cover" />
      {% else %}
        <div
          class="flex h-full w-full items-center justify-center
                 font-mono text-[9px] uppercase text-(--muted)"
        >
          {{ 'IG' if selected.platform == 'instagram' else 'TT' }}
        </div>
      {% endif %}
    </div>

    <div class="min-w-0 flex-1">
      <h2 id="post-detail-heading" class="flex flex-wrap items-baseline gap-1.5">
        <span class="truncate font-sans text-[13px] font-semibold text-(--fg)">
          @{{ username or selected.account_id }}
        </span>
        {% if display_name %}
          <span class="truncate text-[11px] text-(--muted)">· {{ display_name }}</span>
        {% endif %}
      </h2>

      <p class="truncate font-mono text-[11px] text-(--muted)">{{ selected.id }}</p>
    </div>

    <span class="hidden sm:inline">{{ status_pill(selected.status) }}</span>

    <button
      type="button"
      aria-disabled="true"
      title="Replay · coming soon"
      class="inline-flex h-7 cursor-not-allowed items-center gap-1 rounded-md
             border border-(--border-mid) px-2 font-sans text-[11px]
             font-semibold text-(--sub) opacity-65"
    >
      {{ icon("play", 10) }}
      <span>Replay</span>
    </button>

    <div class="hidden items-center gap-0.5 lg:flex">
      {% for ic, label in [("copy", "Copy id"), ("trash", "Delete")] %}
        <button
          type="button"
          aria-label="{{ label }}"
          aria-disabled="true"
          title="{{ label }} · coming soon"
          class="flex h-7 w-7 cursor-not-allowed items-center justify-center
                 rounded text-(--muted) hover:bg-(--hover)"
        >
          {{ icon(ic, 14) }}
        </button>
      {% endfor %}
    </div>
  </header>

  {% call tabs(spec=views_spec) %}
    {{ tablist(spec=views_spec, active=view, label="Post detail views") }}

    {%
      call tabpanel(key="preview", active=view,
      classes="bg-grid flex-1 min-h-0 overflow-y-auto")
    %}
      {% include "pages/posts/_phone_frame.html.j2" %}
    {% endcall %}

    {%
      call tabpanel(key="metadata", active=view,
      classes="flex-1 min-h-0 overflow-y-auto p-6")
    %}
      <dl class="space-y-3 font-mono text-[12px]">
        <div>
          <dt class="uppercase tracking-wider text-(--muted)">Account</dt>
          <dd class="text-(--fg)">@{{ username or selected.account_id }}</dd>
        </div>
        <div>
          <dt class="uppercase tracking-wider text-(--muted)">Platform</dt>
          <dd class="text-(--fg)">{{ selected.platform }}</dd>
        </div>
        {% if selected.caption %}
          <div>
            <dt class="uppercase tracking-wider text-(--muted)">Caption</dt>
            <dd class="whitespace-pre-wrap font-sans text-(--fg)">{{ selected.caption }}</dd>
          </div>
        {% endif %}
        {% if selected.media|length > 1 %}
          <div>
            <dt class="uppercase tracking-wider text-(--muted)">Media items</dt>
            <dd class="text-(--fg)">
              <ol class="list-decimal space-y-1 pl-5">
                {% for m in selected.media %}
                  <li>
                    <span class="uppercase text-(--muted)">{{ m.kind|lower }}</span>
                    <a
                      href="{{ m.url }}"
                      target="_blank"
                      rel="noopener"
                      class="break-all text-(--accent-text) underline"
                      >{{ m.url }}</a
                    >
                  </li>
                {% endfor %}
              </ol>
            </dd>
          </div>
        {% elif selected.media_url %}
          <div>
            <dt class="uppercase tracking-wider text-(--muted)">
              {{ selected.media_type|lower if selected.media_type else 'media' }} url
            </dt>
            <dd>
              <a
                href="{{ selected.media_url }}"
                target="_blank"
                rel="noopener"
                class="break-all text-(--accent-text) underline"
                >{{ selected.media_url }}</a
              >
            </dd>
          </div>
        {% endif %}
        {% if selected.external_ref %}
          <div>
            <dt class="uppercase tracking-wider text-(--muted)">External ref</dt>
            <dd class="break-all text-(--fg)">{{ selected.external_ref }}</dd>
          </div>
        {% endif %}
        {% if selected.platform_post_id %}
          <div>
            <dt class="uppercase tracking-wider text-(--muted)">Platform post id</dt>
            <dd class="break-all text-(--fg)">{{ selected.platform_post_id }}</dd>
          </div>
        {% endif %}
        <div>
          <dt class="uppercase tracking-wider text-(--muted)">Captured</dt>
          <dd class="text-(--fg)">{{ selected.created_at.strftime('%Y-%m-%d %H:%M:%S') }}</dd>
        </div>
        {% if selected.published_at %}
          <div>
            <dt class="uppercase tracking-wider text-(--muted)">Published</dt>
            <dd class="text-(--fg)">{{ selected.published_at.strftime('%Y-%m-%d %H:%M:%S') }}</dd>
          </div>
        {% endif %}
        {% if selected.failure_reason %}
          <div>
            <dt class="uppercase tracking-wider text-(--muted)">Failure reason</dt>
            <dd class="text-(--fg)">{{ selected.failure_reason }}</dd>
          </div>
        {% endif %}
      </dl>
    {% endcall %}
  {% endcall %}
</div>
