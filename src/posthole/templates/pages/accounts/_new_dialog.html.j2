{% from "macros/icon.html.j2" import icon %}
{% from "macros/form_fields.html.j2" import handle_field, text_field %}

<dialog
  id="new-account-dialog"
  data-controller="dialog"
  aria-labelledby="new-account-dialog-title"
  {% if open_dialog %}open{% endif %}
  class="m-auto w-[min(440px,calc(100vw-32px))] rounded-xl border border-(--border)
         bg-(--panel) p-0 text-(--fg) shadow-xl backdrop:bg-black/45
         backdrop:backdrop-blur-sm"
>
  <form
    method="post"
    action="/accounts/new"
    data-controller="platform-types"
    class="flex flex-col gap-4 p-5"
  >
    <header class="flex items-start justify-between gap-3">
      <div>
        <h2 id="new-account-dialog-title" class="font-sans text-[15px] font-bold tracking-tight">
          New test account
        </h2>
        <p class="mt-0.5 text-[12px] text-(--sub)">
          Mock identity your app can authenticate as. No real OAuth round-trip.
        </p>
      </div>
      <button
        type="button"
        aria-label="Close"
        data-action="click->dialog#close"
        class="flex h-7 w-7 items-center justify-center rounded text-(--muted) hover:bg-(--hover) hover:text-(--fg)"
      >
        {{ icon("x", 14) }}
      </button>
    </header>

    <fieldset>
      <legend class="mb-1.5 font-sans text-[11px] font-semibold tracking-[0.02em] text-(--sub)">
        Platform
      </legend>
      <div class="grid grid-cols-2 gap-2" role="radiogroup">
        {% for key, plabel in platforms %}
          <label
            class="flex cursor-pointer items-center justify-center gap-2 rounded-md border
                   border-(--border-mid) px-3 py-2 text-[13px] font-medium
                   has-[:checked]:border-(--accent) has-[:checked]:bg-(--accent-bg)
                   has-[:checked]:text-(--accent-text)
                   has-[:focus-visible]:ring-2 has-[:focus-visible]:ring-(--accent)
                   has-[:focus-visible]:ring-offset-2 has-[:focus-visible]:ring-offset-(--panel)"
          >
            <input
              type="radio"
              name="platform"
              value="{{ key }}"
              data-action="change->platform-types#filter"
              class="sr-only"
              {% if form.platform == key %}checked{% endif %}
              required
            />
            {{ plabel }}
          </label>
        {% endfor %}
      </div>
      {% if form.errors.platform %}
        <p class="mt-1 text-[11px] text-red-600">{{ form.errors.platform }}</p>
      {% endif %}
    </fieldset>

    {{
      handle_field(
        "new-account-username",
        "username",
        form.username,
        error=form.errors.username,
        error_id="new-account-username-error",
        help_id="new-account-username-help",
        placeholder="acme.app",
      )
    }}

    {{
      text_field(
        "new-account-display-name",
        "display_name",
        "Display name",
        form.display_name,
        error=form.errors.display_name,
        error_id="new-account-display-name-error",
        maxlength=80,
        placeholder="Acme",
      )
    }}

    <div>
      <label
        for="new-account-type"
        class="mb-1.5 block font-sans text-[11px] font-semibold tracking-[0.02em] text-(--sub)"
        >Account type</label
      >
      <select
        id="new-account-type"
        name="account_type"
        required
        data-platform-types-target="typeSelect"
        {% if form.errors.account_type %}
          aria-invalid="true" aria-describedby="new-account-type-error"
        {% endif %}
        class="w-full rounded-md border border-(--border-mid) bg-(--panel) px-2.5 py-1.5
               text-[13px] outline-none focus:border-(--accent)"
      >
        <option value="" disabled {% if not form.account_type %}selected{% endif %}>
          Choose type…
        </option>
        {% for plat_key, types in platform_account_types.items() %}
          <optgroup label="{{ plat_key | capitalize }}" data-platform="{{ plat_key }}">
            {% for t in types %}
              <option value="{{ t }}" {% if form.account_type == t %}selected{% endif %}>
                {{ t | replace('_ACCOUNT', '') | replace('_', ' ') | capitalize }}
              </option>
            {% endfor %}
          </optgroup>
        {% endfor %}
      </select>
      {% if form.errors.account_type %}
        <p id="new-account-type-error" class="mt-1 text-[11px] text-red-600">
          {{ form.errors.account_type }}
        </p>
      {% endif %}
    </div>

    <footer class="mt-1 flex items-center justify-end gap-2">
      <button
        type="button"
        data-action="click->dialog#close"
        class="rounded-md border border-(--border-mid) px-3 py-1.5 text-[13px] font-medium text-(--sub)
               hover:bg-(--hover) hover:text-(--fg)"
      >
        Cancel
      </button>
      <button
        type="submit"
        class="rounded-md bg-(--accent) px-3 py-1.5 text-[13px] font-semibold text-white hover:opacity-90"
      >
        Create account
      </button>
    </footer>
  </form>
</dialog>
