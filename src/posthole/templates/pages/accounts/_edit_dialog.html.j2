{% from "macros/icon.html.j2" import icon %}
{% from "macros/form_fields.html.j2" import handle_field, select_field, text_field %}

{% set is_open = edit_form and edit_form.account_id == card.account.id %}
{%
  set values = edit_form if is_open else {
    "username": card.account.username,
    "display_name": card.account.display_name,
    "account_type": card.account.account_type,
    "errors": {},
  }
%}

{% set dialog_id = "edit-account-dialog-" ~ card.account.id %}

{% set type_options = [] %}
{% for t in platform_account_types[card.account.platform] %}
  {% set _ = type_options.append((t, t | replace('_ACCOUNT', '') | replace('_', ' ') | capitalize)) %}
{% endfor %}

<dialog
  id="{{ dialog_id }}"
  data-controller="dialog"
  aria-labelledby="{{ dialog_id }}-title"
  {% if is_open %}open{% endif %}
  class="m-auto w-[min(440px,calc(100vw-32px))] rounded-xl border border-(--border)
         bg-(--panel) p-0 text-(--fg) shadow-xl backdrop:bg-black/45
         backdrop:backdrop-blur-sm"
>
  <form method="post" action="/accounts/{{ card.account.id }}/edit" class="flex flex-col gap-4 p-5">
    <header class="flex items-start justify-between gap-3">
      <div>
        <h2 id="{{ dialog_id }}-title" class="font-sans text-[15px] font-bold tracking-tight">
          Edit @{{ card.account.username }}
        </h2>
        <p class="mt-0.5 text-[12px] text-(--sub)">
          Platform is locked once an account exists. To switch platforms, create a new account.
        </p>
      </div>
      <button
        type="button"
        aria-label="Close"
        data-action="click->dialog#close"
        class="flex h-7 w-7 items-center justify-center rounded text-(--muted) hover:bg-(--hover) hover:text-(--fg)"
      >
        {{ icon("x", 14) }}
      </button>
    </header>

    <div>
      <div
        id="{{ dialog_id }}-platform-label"
        class="mb-1.5 font-sans text-[11px] font-semibold tracking-[0.02em] text-(--sub)"
      >
        Platform
      </div>
      <div
        role="group"
        aria-labelledby="{{ dialog_id }}-platform-label"
        aria-disabled="true"
        class="inline-flex items-center gap-2 rounded-md border border-(--border-mid) bg-(--chip)
               px-3 py-2 text-[13px] font-medium text-(--fg)"
      >
        {{ card.account.platform | capitalize }}
        <span
          class="rounded border border-(--border-mid) px-1 py-0.5 font-mono text-[9px]
                 font-bold tracking-[0.04em] text-(--muted) uppercase"
          >Locked</span
        >
      </div>
    </div>

    {{
      handle_field(
        dialog_id ~ "-username",
        "username",
        values.username,
        error=values.errors.username,
        error_id=dialog_id ~ "-username-error",
        help_id=dialog_id ~ "-username-help",
      )
    }}

    {{
      text_field(
        dialog_id ~ "-display-name",
        "display_name",
        "Display name",
        values.display_name,
        error=values.errors.display_name,
        error_id=dialog_id ~ "-display-name-error",
        maxlength=80,
      )
    }}

    {{
      select_field(
        dialog_id ~ "-type",
        "account_type",
        "Account type",
        values.account_type,
        type_options,
        error=values.errors.account_type,
        error_id=dialog_id ~ "-account-type-error",
      )
    }}

    <footer class="mt-1 flex items-center justify-end gap-2">
      <button
        type="button"
        data-action="click->dialog#close"
        class="rounded-md border border-(--border-mid) px-3 py-1.5 text-[13px] font-medium text-(--sub)
               hover:bg-(--hover) hover:text-(--fg)"
      >
        Cancel
      </button>
      <button
        type="submit"
        class="rounded-md bg-(--accent) px-3 py-1.5 text-[13px] font-semibold text-white hover:opacity-90"
      >
        Save changes
      </button>
    </footer>
  </form>
</dialog>
