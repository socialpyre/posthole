{% from "macros/icon.html.j2" import icon %}

<header
  class="flex h-13 shrink-0 items-center gap-3 border-b border-(--border)
         bg-(--panel) px-4 lg:h-12"
>
  <button
    aria-label="Open menu"
    class="flex h-8 w-8 items-center justify-center rounded text-(--sub) hover:bg-(--hover) lg:hidden"
    data-action="click->sidebar#open"
    data-controller="sidebar"
    type="button"
  >
    {{ icon("menu", 18) }}
  </button>

  <a aria-label="posthole home" class="flex items-center gap-2 pr-2 text-(--accent)" href="/">
    {{ icon("logo", 20) }}
    <span class="font-sans text-[14px] font-bold tracking-[-0.01em] text-(--fg)">posthole</span>
    <span
      class="font-mono text-[10px] text-(--muted) leading-none
             rounded border border-(--border-mid) px-1.5 py-0.5"
    >
      v{{ APP_VERSION }}
    </span>
  </a>

  {% if request.url.path is current_for('/posts') %}
    <div class="hidden flex-1 sm:block">
      <label
        class="relative block max-w-130"
        data-controller="search"
        data-search-delay-value="200"
      >
        <span class="pointer-events-none absolute top-1/2 left-2.5 -translate-y-1/2 text-(--muted)">
          {{ icon("search", 14) }}
        </span>

        <input
          id="topbar-search"
          type="search"
          name="q"
          value="{{ request.query_params.q or '' }}"
          placeholder="Search captions and accounts"
          aria-label="Search posts"
          aria-keyshortcuts="Meta+K Control+K"
          data-search-target="input"
          data-action="input->search#query"
          data-turbo-permanent
          class="block w-full rounded-md border border-(--border) bg-(--bg)
                 py-1.5 pr-16 pl-8 font-sans text-[12px] text-(--fg)
                 placeholder:text-(--muted) focus:border-(--accent)
                 focus:outline-none"
        />

        <button
          type="button"
          data-action="click->search#clear"
          aria-label="Clear search"
          class="search-clear absolute top-1/2 right-10 flex h-5 w-5
                 -translate-y-1/2 items-center justify-center rounded
                 text-(--muted) hover:bg-(--hover) hover:text-(--fg)"
        >
          {{ icon("x", 12) }}
        </button>

        <kbd
          class="pointer-events-none absolute top-1/2 right-2 flex h-5
                 -translate-y-1/2 items-center rounded
                 border border-(--border-mid) bg-(--panel) px-1.5
                 font-mono text-[10px] text-(--muted)"
          >⌘K</kbd
        >
      </label>
    </div>
  {% else %}
    <span class="flex-1"></span>
  {% endif %}

  <div class="ml-auto flex items-center gap-2">
    <span
      data-controller="liveness"
      data-liveness-stream-value="/_health/stream"
      data-liveness-state="live"
      aria-label="Server connection status"
      class="liveness-pill hidden items-center gap-1.5 rounded-md border
             px-2.5 py-1 font-sans text-[11px] font-semibold sm:inline-flex"
    >
      <span class="liveness-dot h-1.5 w-1.5 rounded-full"></span>
      <span data-liveness-target="label" data-liveness-label="live">live</span>
      <span data-liveness-target="label" data-liveness-label="reconnecting" hidden
        >reconnecting</span
      >
      <span data-liveness-target="label" data-liveness-label="offline" hidden>offline</span>
    </span>

    <button
      aria-label="Cycle theme: light, dark, system"
      class="flex h-[30px] w-[30px] items-center justify-center rounded-md
             border border-(--border) text-(--sub) hover:bg-(--hover)"
      data-action="click->theme#cycle"
      data-controller="theme"
      type="button"
    >
      <span data-theme-icon="light">{{ icon("sun", 15) }}</span>
      <span data-theme-icon="dark">{{ icon("moon", 15) }}</span>
      <span data-theme-icon="system">{{ icon("monitor", 15) }}</span>
    </button>
  </div>
</header>
