{
  "name": "postpit-assets",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node web/build.mjs",
    "watch": "node web/build.mjs --watch",
    "css:build": "tailwindcss -i web/styles.css -o src/postpit/static/app.css --minify",
    "css:watch": "tailwindcss -i web/styles.css -o src/postpit/static/app.css --watch",
    "assets:build": "run-p build css:build",
    "assets:watch": "run-p watch css:watch",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@hotwired/stimulus": "^3.2.2",
    "@hotwired/turbo": "^8.0.13"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.0",
    "esbuild": "^0.28.0",
    "npm-run-all2": "^8.0.4",
    "prettier": "^3.8.3",
    "prettier-plugin-jinja-template": "^2.2.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.0",
    "varlock": "^1.1.0"
  },
  "packageManager": "pnpm@11.0.9"
}
